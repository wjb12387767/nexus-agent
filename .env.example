# Nexus Agent — Docker Compose environment template.
#
# 1. Copy this file to `.env` (in the repo root, next to docker-compose.yml):
#      cp .env.example .env
# 2. Fill in your LLM endpoint credentials.
# 3. (Optional) adjust WORKSPACE_DIR to point at the project you want the
#    agent to work on.
# 4. Run:  docker compose up -d
#
# All variables below are read by docker-compose.yml. Lines starting with `#`
# are comments; uncomment and edit the ones you need.

# ─────────────────────────────────────────────────────────────────────────────
# LLM endpoint (required)
# ─────────────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible relay endpoint. Examples:
#   - Local relay:        http://host.docker.internal:18317/v1
#   - OpenAI direct:      https://api.openai.com/v1
#   - Anthropic relay:    https://api.anthropic.com/v1
#
# Notes:
#   - `host.docker.internal` resolves to the Docker host IP from inside the
#     container. Use it to reach services on your host machine.
#   - The API key is passed to the agent and the LightRAG bridge verbatim.

LLM_API_BASE=http://host.docker.internal:18317/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=grok-4.5

# ─────────────────────────────────────────────────────────────────────────────
# Workspace (optional)
# ─────────────────────────────────────────────────────────────────────────────
# The directory the agent will operate in (mounted into /work inside the
# container). Defaults to ./workspace (a sibling of the repo root).
#
# Example values:
#   WORKSPACE_DIR=./workspace                   # default, repo-local sandbox
#   WORKSPACE_DIR=/home/me/projects/my-app      # absolute path on host
#   WORKSPACE_DIR=D:\dev\my-project             # Windows path

# WORKSPACE_DIR=./workspace

# ─────────────────────────────────────────────────────────────────────────────
# Nexus image tag (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Which prebuilt image to pull. Leave as-is for the beta release. Set to
# `main` to use the rolling dev build from the main branch.

NEXUS_TAG=1.0.0-beta
