{
  "name": "@nexus-agent/grpc",
  "version": "17.0.2",
  "description": "gRPC server for Nexus Agent — bidirectional streaming protocol ported from OpenClaude",
  "private": true,
  "type": "module",
  "homepage": "https://nexus.agent",
  "author": "Nexus Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjb12387767/nexus-agent.git",
    "directory": "packages/nexus-grpc"
  },
  "keywords": [
    "grpc",
    "nexus",
    "agent",
    "streaming",
    "proto"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@grpc/grpc-js": "catalog:",
    "@grpc/proto-loader": "catalog:",
    "@oh-my-pi/pi-agent-core": "catalog:",
    "@oh-my-pi/pi-ai": "catalog:",
    "@oh-my-pi/pi-catalog": "catalog:",
    "@oh-my-pi/pi-utils": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "proto",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./proto": {
      "import": "./proto/nexus.proto"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  }
}
