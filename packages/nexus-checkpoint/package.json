{
  "name": "@nexus-agent/checkpoint",
  "version": "17.0.2",
  "description": "Filesystem-level checkpoint/rewind system NAPI bindings for Nexus Agent",
  "type": "module",
  "homepage": "https://nexus.agent",
  "author": "Can Bolük",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjb12387767/nexus-agent.git",
    "directory": "packages/nexus-checkpoint"
  },
  "bugs": {
    "url": "https://github.com/wjb12387767/nexus-agent/issues"
  },
  "keywords": [
    "napi",
    "rust",
    "checkpoint",
    "rewind",
    "snapshot",
    "rollback",
    "cow",
    "reflink"
  ],
  "main": "./native/index.js",
  "types": "./native/index.d.ts",
  "scripts": {
    "build": "napi build --platform --release --manifest-path ../../crates/nexus-checkpoint/Cargo.toml -o native --no-js",
    "build:debug": "napi build --platform --manifest-path ../../crates/nexus-checkpoint/Cargo.toml -o native --no-js",
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:",
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "napi": {
    "binaryName": "nexus-checkpoint",
    "triples": {}
  },
  "files": [
    "src",
    "native",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./native/index.d.ts",
      "import": "./native/index.js"
    }
  }
}
