{
  "name": "@nexus-agent/bash-ast",
  "version": "1.0.0-beta",
  "description": "AST-based bash command security analysis for Nexus Agent (port of OpenClaude ast.ts security walker)",
  "type": "module",
  "homepage": "https://nexus.agent",
  "author": "Nexus Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjb12387767/nexus-agent.git",
    "directory": "packages/nexus-bash-ast"
  },
  "bugs": {
    "url": "https://github.com/wjb12387767/nexus-agent/issues"
  },
  "keywords": [
    "bash",
    "ast",
    "tree-sitter",
    "security",
    "napi",
    "nexus"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@oh-my-pi/pi-natives": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  }
}
