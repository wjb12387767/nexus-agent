{
  "name": "@oh-my-pi/nexus-sandbox",
  "version": "17.0.2",
  "description": "OS-level sandbox (Landlock/Seatbelt/ISO FS) NAPI bindings for Nexus Agent",
  "type": "module",
  "homepage": "https://nexus.agent",
  "author": "Can Bolük",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nexus-agent/nexus-agent.git",
    "directory": "packages/nexus-sandbox"
  },
  "bugs": {
    "url": "https://github.com/nexus-agent/nexus-agent/issues"
  },
  "keywords": [
    "napi",
    "rust",
    "sandbox",
    "landlock",
    "seatbelt",
    "iso-fs",
    "security"
  ],
  "main": "./native/index.js",
  "types": "./native/index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:",
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "napi": {
    "binaryName": "nexus-sandbox",
    "triples": {}
  },
  "files": [
    "src",
    "native",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./native/index.d.ts",
      "import": "./native/index.js"
    }
  }
}
