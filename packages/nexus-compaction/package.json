{
  "name": "@nexus-agent/compaction",
  "version": "17.0.2",
  "description": "Multi-level compaction engine for Nexus Agent — ported from Grok Build's inter/intra/code/history compaction algorithms",
  "private": true,
  "type": "module",
  "homepage": "https://nexus.agent",
  "author": "Nexus Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjb12387767/nexus-agent.git",
    "directory": "packages/nexus-compaction"
  },
  "keywords": [
    "nexus",
    "compaction",
    "context",
    "grok",
    "summarization",
    "agent"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  }
}
